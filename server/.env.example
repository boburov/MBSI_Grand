# PostgreSQL ulanish manzili
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/landing?schema=public"

# Admin GET endpoint uchun maxfiy kalit (x-api-key header).
# Tasodifiy uzun qiymat qo'ying, masalan: openssl rand -hex 32
ADMIN_API_KEY="change-me-to-a-long-random-string"

# Server porti
PORT=3000

# Client origin (CORS) — vergul bilan ajratib bir nechta yozish mumkin
CLIENT_ORIGIN="http://localhost:5173"
