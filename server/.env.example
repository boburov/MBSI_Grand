# Server
PORT=3000
CLIENT_ORIGIN=http://localhost:5173        # CORS uchun ruxsat etilgan origin (Vite dev)
SERVER_URL=http://localhost:3000           # fayl URL bazasi: ${SERVER_URL}/uploads/<file>

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/landing

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Telegram (sertifikatlar tushadigan kanal). Bo'sh qoldirilsa — Telegram bosqichi o'tkazib yuboriladi.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=                        # @kanal yoki -1001234567890

# Admin panel login (JWT shu credential bilan beriladi)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
